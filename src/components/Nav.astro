---
import { getCollection } from "astro:content";
import { nav, site } from "../site.config";

// hide the Blog item until there's at least one published post
const hasPosts = (await getCollection("blog", (p) => !p.data.draft)).length > 0;
const items = nav.filter((n) => n.href !== "/blog" || hasPosts);

// active link: match exact for "/", prefix for the rest
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="hidden md:block sticky top-0 z-50 border-b border-border bg-bg/70 backdrop-blur">
  <nav class="container-wide relative flex h-14 items-center justify-center gap-4" aria-label="Main">
    <a href="/" class="absolute left-5 flex items-center gap-2.5 transition-opacity hover:opacity-80" aria-label="Home">
      <img src="/favicon.svg" alt="" class="h-7 w-7 rounded-lg" />
      <span class="text-sm font-semibold tracking-tight">{site.name}</span>
    </a>

    <ul class="hidden md:flex items-center gap-1 text-sm">
      {
        items.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "nav-link rounded-md px-3 py-1.5 transition-colors hover:text-fg",
                isActive(item.href) ? "text-fg" : "text-muted",
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      id="cmdk-hint"
      type="button"
      class="absolute right-5 hidden lg:inline-flex items-center gap-1 rounded-md border border-border bg-surface px-2 py-1 font-mono text-[11px] text-muted transition-colors hover:border-accent hover:text-accent"
      aria-label="Open command palette"
    >
      ⌘K
    </button>
  </nav>
</header>

<!-- Mobile Nav FAB -->
<div class="md:hidden fixed bottom-6 right-6 z-50">
  <div id="mobile-menu" class="hidden absolute bottom-16 right-0 w-48 rounded-xl border border-border bg-surface p-2 shadow-xl flex-col gap-1">
    {items.map(item => (
      <a href={item.href} class:list={[
        "rounded-md border border-transparent px-4 py-2.5 text-sm font-medium transition-colors hover:border-accent hover:text-accent hover:bg-surface-2",
        isActive(item.href) ? "text-fg bg-surface-2" : "text-muted"
      ]}>
        {item.label}
      </a>
    ))}
  </div>
  <button
    id="mobile-menu-btn"
    class="flex h-14 w-14 items-center justify-center rounded-full border border-border bg-surface text-fg shadow-xl transition-colors hover:border-accent hover:text-accent"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="menu-icon"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="close-icon hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
  </button>
</div>

<script>
  // Fully delegated (no element-bound listeners), so it survives view-transition
  // swaps without re-binding.
  const setOpen = (open: boolean) => {
    const menu = document.getElementById("mobile-menu");
    const btn = document.getElementById("mobile-menu-btn");
    menu?.classList.toggle("hidden", !open);
    menu?.classList.toggle("flex", open);
    btn?.querySelector(".menu-icon")?.classList.toggle("hidden", open);
    btn?.querySelector(".close-icon")?.classList.toggle("hidden", !open);
    btn?.setAttribute("aria-expanded", String(open));
    btn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  };

  document.addEventListener("click", (e) => {
    const target = e.target as Element | null;

    if (target?.closest?.("#cmdk-hint")) {
      window.dispatchEvent(new CustomEvent("cmdk:open"));
      return;
    }

    const menu = document.getElementById("mobile-menu");
    if (!menu) return;
    const isOpen = !menu.classList.contains("hidden");
    if (target?.closest?.("#mobile-menu-btn")) {
      setOpen(!isOpen);
    } else if (isOpen && !menu.contains(target as Node)) {
      setOpen(false);
    }
  });
</script>
