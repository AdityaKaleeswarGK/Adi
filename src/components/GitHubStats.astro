---
// GitHub activity — a single dark contribution-activity graph (no stats card,
// no repo list). Uses a free external image service that matches the theme.
import { site } from "../site.config";

const username = site.githubUsername;
const graphUrl =
  `https://github-readme-activity-graph.vercel.app/graph?username=${username}` +
  `&bg_color=141417&color=e9e9ec&line=10b981&point=34d399&area=true` +
  `&area_color=10b981&title_color=e9e9ec&hide_border=true&radius=12`;
---

{
  username && (
    <section>
      <h2 class="mb-4 text-lg font-semibold">GitHub activity</h2>
      <div class="overflow-hidden rounded-xl border border-border bg-surface">
        <img
          src={graphUrl}
          alt={`${username}'s contribution activity`}
          loading="lazy"
          class="w-full"
        />
      </div>
    </section>
  )
}
