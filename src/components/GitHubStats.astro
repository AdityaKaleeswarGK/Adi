---
// GitHub activity — a real contribution heatmap (GitHub-style green squares),
// rendered client-side from the public contributions API so it's always fresh.
// Colors come straight from the theme tokens (see .heat-* in global.css).
import { site } from "../site.config";

const username = site.githubUsername;
---

{
  username && (
    <section id="gh-activity" data-username={username}>
      <div class="mb-4 flex items-baseline justify-between gap-3">
        <h2 class="text-lg font-semibold">GitHub activity</h2>
        <a
          href={`https://github.com/${username}`}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs text-faint transition-colors hover:text-accent"
        >
          @{username} ↗
        </a>
      </div>

      <div class="rounded-xl border border-border bg-surface p-4 sm:p-5">
        <div class="overflow-x-auto pb-1" data-heatmap-scroll>
          <div class="min-w-[640px]">
            <div data-heatmap-months class="heat-months" aria-hidden="true" />
            <div data-heatmap class="heatmap" role="img" aria-label={`${username}'s GitHub contribution heatmap, last 12 months`} />
          </div>
        </div>

        <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
          <p data-heatmap-total class="font-mono text-xs text-faint">loading contributions…</p>
          <div class="flex items-center gap-1.5 font-mono text-[10px] text-faint" aria-hidden="true">
            less
            {[0, 1, 2, 3, 4].map((l) => (
              <span class={`heat-cell heat-${l} inline-block !h-[10px] !w-[10px]`} />
            ))}
            more
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  // Fetched once per visit, cached in the module so view-transition
  // navigations back to the home page re-render instantly.
  type Day = { date: string; count: number; level: number };
  let cache: { total: number; days: Day[] } | null = null;

  const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

  const load = async (username: string) => {
    if (cache) return cache;
    const res = await fetch(`https://github-contributions-api.jogruber.de/v4/${username}?y=last`);
    if (!res.ok) throw new Error(`contributions API ${res.status}`);
    const json = await res.json();
    cache = { total: json.total?.lastYear ?? 0, days: json.contributions ?? [] };
    return cache;
  };

  const render = async () => {
    const section = document.getElementById("gh-activity");
    const grid = section?.querySelector<HTMLElement>("[data-heatmap]");
    if (!section || !grid || grid.childElementCount > 0) return;

    try {
      const { total, days } = await load(section.dataset.username!);
      if (!days.length) throw new Error("no data");

      // group days into GitHub-style Sunday-first week columns
      const weeks: Day[][] = [];
      let week: Day[] = new Array(new Date(days[0].date + "T00:00:00").getDay()).fill(null);
      for (const d of days) {
        week.push(d);
        if (week.length === 7) {
          weeks.push(week);
          week = [];
        }
      }
      if (week.length) weeks.push(week);

      const frag = document.createDocumentFragment();
      const monthsRow = section.querySelector<HTMLElement>("[data-heatmap-months]");
      let lastMonth = -1;

      weeks.forEach((w) => {
        const col = document.createElement("div");
        col.className = "heat-week";
        w.forEach((d) => {
          const cell = document.createElement("div");
          cell.className = d ? `heat-cell heat-${d.level}` : "heat-cell";
          if (!d) cell.style.visibility = "hidden";
          if (d) {
            const nice = new Date(d.date + "T00:00:00").toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
            });
            cell.title = `${d.count} contribution${d.count === 1 ? "" : "s"} on ${nice}`;
          }
          col.appendChild(cell);
        });
        frag.appendChild(col);

        // month label above the first week of each month
        const first = w.find(Boolean);
        const m = first ? new Date(first.date + "T00:00:00").getMonth() : -1;
        const label = document.createElement("span");
        if (m !== -1 && m !== lastMonth) {
          label.textContent = MONTHS[m];
          lastMonth = m;
        }
        monthsRow?.appendChild(label);
      });

      grid.appendChild(frag);

      const totalEl = section.querySelector<HTMLElement>("[data-heatmap-total]");
      if (totalEl) totalEl.textContent = `${total.toLocaleString()} contributions in the last year`;

      // on narrow screens, start scrolled to the most recent weeks
      const scroller = section.querySelector<HTMLElement>("[data-heatmap-scroll]");
      if (scroller) scroller.scrollLeft = scroller.scrollWidth;
    } catch {
      // API down → hide the section rather than show a broken card
      section.style.display = "none";
    }
  };

  document.addEventListener("astro:page-load", render);
</script>
