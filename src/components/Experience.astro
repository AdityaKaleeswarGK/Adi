---
// Experience: a grid of compact cards. Click one → a large modal opens covering
// most of the screen with the full details + links. Click ✕ / backdrop / Esc to
// close. Content comes from src/content/experience/ (sorted by `order`).
import { getCollection, render } from "astro:content";
import GitHubIcon from "./GitHubIcon.astro";

const entries = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order,
);
const items = await Promise.all(
  entries.map(async (e) => ({ data: e.data, Content: (await render(e)).Content })),
);
---

{
  items.length > 0 && (
    <section id="experience">
      <div class="mb-6 flex items-baseline justify-between">
        <h2 class="text-lg font-semibold">Experience</h2>
      </div>

      <div class="space-y-4">
        {items.map((it, i) => (
          <button type="button" class="card card-hover flex w-full flex-col text-left" data-exp-open={i}>
            <p class="font-medium text-fg">{it.data.role}</p>
            <p class="mt-1 text-sm text-muted">
              {it.data.org}
              {it.data.location ? ` · ${it.data.location}` : ""}
            </p>
            {it.data.summary && (
              <p class="mt-3 flex-1 text-sm text-faint">{it.data.summary}</p>
            )}
            <div class="mt-4 flex items-center justify-between text-xs text-faint">
              <time>{it.data.start} – {it.data.end}</time>
              <span class="link-accent">Expand →</span>
            </div>
          </button>
        ))}
      </div>

      {/* Modals (one per role) */}
      {items.map((it, i) => {
        const Body = it.Content;
        return (
          <div
            class="exp-modal fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6"
            data-exp={i}
            role="dialog"
            aria-modal="true"
            aria-label={`${it.data.role} — ${it.data.org}`}
          >
            <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close />
            <div class="exp-panel relative z-10 max-h-[90vh] w-full max-w-4xl overflow-y-auto rounded-2xl border border-border bg-surface p-8 shadow-2xl sm:p-10">
              <button
                type="button"
                class="absolute right-4 top-4 text-2xl leading-none text-faint transition-colors hover:text-fg"
                data-close
                aria-label="Close"
              >
                ×
              </button>
              <p class="font-mono text-xs text-accent">{it.data.start} – {it.data.end}</p>
              <h3 class="mt-1 text-3xl font-bold tracking-tight">{it.data.role}</h3>
              <p class="mt-1 text-muted">
                {it.data.org}
                {it.data.location ? ` · ${it.data.location}` : ""}
              </p>
              <div class="prose mt-6">
                <Body />
              </div>
              {it.data.links.length > 0 && (
                <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 border-t border-border pt-5">
                  {it.data.links.map((l) => (
                    <a
                      href={l.url}
                      class="link-accent inline-flex items-center gap-1.5 text-sm"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <GitHubIcon class="h-3.5 w-3.5" />
                      {l.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </section>
  )
}

<script>
  let lastFocused: HTMLElement | null = null;

  const open = (i: string) => {
    const m = document.querySelector<HTMLElement>(`.exp-modal[data-exp="${i}"]`);
    if (!m) return;
    lastFocused = document.activeElement as HTMLElement;
    m.classList.remove("hidden");
    m.classList.add("flex");
    document.body.style.overflow = "hidden";
    // move keyboard focus into the dialog
    m.querySelector<HTMLElement>("[data-close][aria-label]")?.focus();
  };
  const closeAll = () => {
    const wasOpen = document.querySelector(".exp-modal.flex");
    document.querySelectorAll<HTMLElement>(".exp-modal").forEach((m) => {
      m.classList.add("hidden");
      m.classList.remove("flex");
    });
    document.body.style.overflow = "";
    if (wasOpen) lastFocused?.focus();
  };

  document
    .querySelectorAll<HTMLElement>("[data-exp-open]")
    .forEach((b) => b.addEventListener("click", () => open(b.dataset.expOpen!)));
  document
    .querySelectorAll<HTMLElement>("[data-close]")
    .forEach((el) => el.addEventListener("click", closeAll));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAll();
  });
</script>
