---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const posts = (await getCollection("blog", (p) => !p.data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);

// ~220 wpm; external (url) posts have no local body, so no estimate for them
const readMins = (body?: string) =>
  body ? Math.max(1, Math.round(body.split(/\s+/).length / 220)) : null;
---

<BaseLayout title="Blog" description="Writing & notes.">
  <div class="container-tight">
    <PageHeader title="Blog" subtitle="Writing, notes, and things I'm figuring out." />

    {
      posts.length === 0 ? (
        <div class="rounded-xl border border-dashed border-border bg-surface/50 p-8 text-center">
          <p class="font-mono text-sm text-accent">$ ls posts/ <span class="text-faint">— empty</span></p>
          <p class="mt-3 text-sm text-muted">
            Nothing published yet — the first post is in the works. Meanwhile, the
            <a href="/#exploring" class="link-accent">exploring timeline</a> is where the action is.
          </p>
        </div>
      ) : (
        <ul class="space-y-4">
          {posts.map((p) => {
            const external = Boolean(p.data.url);
            const href = p.data.url ?? `/blog/${p.id}`;
            const mins = external ? null : readMins(p.body);
            return (
              <li>
                <a
                  href={href}
                  target={external ? "_blank" : undefined}
                  rel={external ? "noopener noreferrer" : undefined}
                  class="card card-hover block"
                >
                  <div class="flex items-baseline justify-between gap-3">
                    <h2 class="font-medium text-fg">
                      {p.data.title}
                      {external && <span class="text-faint"> ↗</span>}
                    </h2>
                    <span class="flex shrink-0 items-center gap-2 text-xs text-faint">
                      {mins && <span class="font-mono">{mins} min</span>}
                      <time>{fmt(p.data.date)}</time>
                    </span>
                  </div>
                  {p.data.description && (
                    <p class="mt-1 text-sm text-muted">{p.data.description}</p>
                  )}
                  {p.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1.5">
                      {p.data.tags.map((t) => <span class="tag">{t}</span>)}
                    </div>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</BaseLayout>
