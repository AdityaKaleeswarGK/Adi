---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Exploring from "../components/Exploring.astro";
import FeaturedProjects from "../components/FeaturedProjects.astro";
import GitHubStats from "../components/GitHubStats.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { site } from "../site.config";

// latest exploring entry drives the live "now:" chip in both heroes
const latest = (await getCollection("exploring")).sort(
  (a, b) => +b.data.date - +a.data.date,
)[0];
---

<BaseLayout>
  <div class="container-wide space-y-20">
    <!-- ── Hero + get in touch ────────────────────────────────────────── -->
    <!-- ── Desktop Hero ───────────────────────────────────────────────── -->
    <section class="hidden md:grid items-center gap-10 md:grid-cols-[1.2fr_1fr]">
      <div>
        <p class="mb-3 font-mono text-sm text-accent">hi, I'm</p>
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{site.name}</h1>
        
        <p class="mt-3 font-mono text-[14px] text-muted">@{site.githubUsername.toLowerCase()}</p>

        {latest && (
          <a href="#exploring" class="now-chip group mt-4 inline-flex max-w-full items-center gap-2.5 rounded-full border border-accent/30 bg-accent-soft px-4 py-1.5 text-[13px] transition-all duration-300 hover:border-accent hover:shadow-[0_0_18px_rgba(16,185,129,0.25)]">
            <span class="relative flex h-1.5 w-1.5 shrink-0">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
            </span>
            <span class="font-mono text-[11px] uppercase tracking-widest text-accent">now</span>
            <span class="truncate text-fg/90">{latest.data.title}</span>
            <svg class="h-3.5 w-3.5 shrink-0 text-muted transition-transform group-hover:translate-y-0.5 group-hover:text-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
        )}

        <p class="mt-4 max-w-xl text-muted leading-relaxed">{site.intro}</p>

        <div class="mt-8 flex items-center gap-3">
          <a
            href="/projects"
            class="btn-magnetic inline-flex items-center gap-1.5 rounded-xl bg-accent px-5 py-2.5 text-sm font-medium text-[#06120d] transition-colors hover:bg-accent-hover"
          >
            View projects →
          </a>
          <a
            href="/resume"
            class="btn-magnetic inline-flex items-center rounded-xl border border-border px-5 py-2.5 text-sm transition-colors hover:border-accent hover:text-accent"
          >
            Resume
          </a>
        </div>

        <!-- get in touch -->
        <SocialLinks class="flex items-center gap-6 mt-7 text-muted" />
      </div>

      <!-- Hero image (slightly dimmed so it doesn't outshine the intro text) -->
      <img
        src={site.heroImage}
        alt={site.name}
        class="mx-auto aspect-square w-full max-w-md rounded-2xl border border-border object-cover brightness-[.94] saturate-[.92] md:max-w-none"
      />
    </section>

    <!-- ── Mobile Hero (Bento Style) ──────────────────────────────────── -->
    <section class="md:hidden flex flex-col rounded-3xl border border-border bg-surface overflow-hidden">
      <img src={site.heroImage} alt={site.name} class="w-full h-64 object-cover" />
      
      <div class="p-6 flex flex-col gap-4">
        <h1 class="text-3xl font-bold tracking-tight">hi, i'm {site.name.toLowerCase().split(' ')[0]}</h1>
        
        <p class="-mt-3 font-mono text-[13px] text-muted">@{site.githubUsername.toLowerCase()}</p>

        {latest && (
          <a href="#exploring" class="group -mt-1 inline-flex max-w-full items-center gap-2 self-start rounded-full border border-accent/30 bg-accent-soft px-3.5 py-1.5 text-[12px] transition-all duration-300 hover:border-accent">
            <span class="relative flex h-1.5 w-1.5 shrink-0">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
            </span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-accent">now</span>
            <span class="truncate text-fg/90">{latest.data.title}</span>
            <svg class="h-3 w-3 shrink-0 text-muted transition-transform group-hover:translate-y-0.5 group-hover:text-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
        )}
        
        <p class="text-[15px] text-muted leading-relaxed">
          {site.intro}
        </p>

        <SocialLinks
          class="flex items-center gap-5 mt-2 mb-3 text-muted"
          linkClass="hover:text-accent transition-colors"
        />

        <div class="flex flex-col gap-2">
          <a href="/experience" class="flex items-center justify-center w-full rounded-xl py-3 text-[15px] font-medium transition-transform hover:opacity-80 active:scale-95" style="background-color: #059669; color: #ffffff;">
            Experience ↗
          </a>
          <div class="flex gap-2">
            <a href="/projects" class="flex items-center justify-center flex-1 rounded-xl border border-border bg-transparent py-3 text-[15px] font-medium transition-colors hover:border-accent active:scale-95 text-fg">
              Projects ↗
            </a>
            <a href="/resume" class="flex items-center justify-center flex-1 rounded-xl border border-border bg-transparent py-3 text-[15px] font-medium transition-colors hover:border-accent active:scale-95 text-fg">
              Resume ↗
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── GitHub activity (contribution heatmap) ───────────────────────── -->
    <GitHubStats />

    <!-- ── Selected work — the four flagship projects ───────────────────── -->
    <FeaturedProjects />

    <!-- ── What I'm working on (Exploring) ───────────────────────────── -->
    <section id="exploring" class="scroll-mt-24">
      <div class="mb-6 flex items-baseline justify-between">
        <h2 class="text-lg font-semibold">Currently Exploring</h2>
      </div>
      <Exploring />
    </section>
  </div>
</BaseLayout>
